{
  "name": "blazedemo147adv",
  "version": "1.0.0",
  "description": "Projeto automação web com playwright",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:bdd": "cucumber-js features/**/*.feature --require steps/**/*.steps.js --require support/**/*.js --format json:reports/cucumber_report.json",
    "test:bdd:headed": "cross-env HEADLESS=false npm run test:bdd",
    "report": "node generate_report.js"
  },
  "keywords": [
    "playwright",
    "cucumber"
  ],
  "author": "Rodrigo Sanceverino",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "cross-env": "^10.1.0",
    "cucumber-html-reporter": "^7.2.0"
  },
  "dependencies": {
    "@cucumber/cucumber": "^12.8.0"
  }
}
